# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/sociosphere

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# Redis Cache (REQUIRED for production - cache + job queues)
REDIS_URL=redis://localhost:6379

# RabbitMQ (Optional - for distributed message queue)
RABBITMQ_URL=amqp://localhost

# Logging
LOG_LEVEL=info

# HTTPS Configuration
HTTPS_ENABLED=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# Rate Limiting Configuration (Optional)
RL_GENERAL_WINDOW_MS=600000
RL_GENERAL_MAX=300
RL_AUTH_WINDOW_MS=900000
RL_AUTH_MAX=20

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Giphy API (GIF Search)
GIPHY_API_KEY=your_giphy_api_key

# Twilio (SMS/OTP - Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# AI Integration APIs (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# AI Integration APIs (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Hugging Face (AI Text & Image Generation)
HF_API_KEY=your_huggingface_api_key
HF_API_BASE=https://router.huggingface.co
HF_TEXT_MODEL=meta-llama/Llama-3.2-3B-Instruct
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Error Tracking (Sentry) - Optional
SENTRY_DSN=your_sentry_dsn

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password
